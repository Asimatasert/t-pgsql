    --log-level <level>           debug|info|warn|error
    -v, --verbose                 Verbose output
    -q, --quiet                   Minimal output
    -y, --yes                     Skip confirmations
    --dry-run                     Show actions without executing
    --no-meta                     Don't write .meta files
    -h, --help                    Show help
    --version                     Show version

EXAMPLES:
